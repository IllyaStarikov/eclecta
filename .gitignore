# build output
dist/
.astro/

# deps
node_modules/

# env
.env
.env.production
# local pyenv interpreter pin (machine-specific virtualenv name)
.python-version
.venv/

# os
.DS_Store

# logs
npm-debug.log*

# screenshots & test artifacts
screenshots/
test-results/
playwright-report/

# global gitignore ignores lib/ — this repo needs src/lib
!src/lib/
!src/lib/**

# naming-exploration notes — not part of the site; kept out of the published
# repo so the pipeline's publish guard sees a clean tree
docs/naming/

# pipeline/ holds the signalpipe source for versioning; it is NOT built or run
# from here (the launchd worker runs a copy under ~/.local/state). Keep Python
# caches untracked-and-ignored so the worker's publish guard never sees dirt.
pipeline/**/__pycache__/
*.py[cod]
pipeline/signalpipe/sources.opml
