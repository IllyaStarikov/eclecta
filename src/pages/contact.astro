---
import Base from '../layouts/Base.astro';
import { site, href } from '../site';
---
<Base title={`Contact | ${site.name}`} description={`${site.name} is an automated publication. Corrections and ideas go to ${site.author}.`}>
  <article class="article measure measure--center">
    <header class="article__head">
      <span class="label">Contact</span>
      <h1 class="article__title">There is no newsroom.</h1>
    </header>
    <div class="prose">
      <p>
        {site.name} is an automated publication, built and run by
        <a href={site.authorUrl}>{site.author}</a>. No staff, no tip line, no
        comment section.
      </p>
      <p>
        Corrections, broken links, and ideas are welcome all the same. A
        machine wrote the words, but a person answers for them. Reach out via
        <a href={site.contactUrl}>starikov.co/contact</a>.
      </p>
      <p>
        If something here is wrong, say which pick or digest and what the
        primary source actually says. Wrong gets fixed.
      </p>
    </div>
    <a class="arrow-link back" href={href('/')}>← Front page</a>
  </article>
</Base>
