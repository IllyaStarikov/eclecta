---
import Base from '../layouts/Base.astro';
import { site, href } from '../site';
---
<Base title={`404 — ${site.name}`} description="Page not found." compactHeader>
  <section class="nf">
    <p class="nf__code" aria-hidden="true">404</p>
    <h1 class="nf__line">This page fell below the relevance threshold.</h1>
    <nav class="nf__links" aria-label="Elsewhere">
      <a class="arrow-link" href={href('/')}>Front</a>
      <a class="arrow-link" href={href('/archive/')}>Archive</a>
      <a class="arrow-link" href={href('/feeds/')}>Feeds</a>
    </nav>
  </section>

  <style>
    /* design-lint-allow: display-xl — the 404 numeral is the one sanctioned
       display stunt (design-language.md §2.2); everything else is on tokens. */
    .nf {
      text-align: center;
      padding: clamp(3rem, 12vh, 7rem) 0 3rem;
    }
    .nf__code {
      font-family: var(--sans);
      font-weight: 800;
      font-size: clamp(6rem, 24vw, 14rem);
      line-height: 0.85;
      letter-spacing: -0.05em;
      margin: 0;
      color: var(--accent);
    }
    .nf__line {
      font-family: var(--serif);
      font-weight: 400;
      font-style: italic;
      font-size: var(--h3);
      color: var(--ink-soft);
      margin: var(--space-5) 0 var(--space-6);
    }
    .nf__links {
      display: inline-flex;
      gap: 1.8rem;
      border-top: 1px solid var(--hairline-bold);
      padding-top: var(--space-4);
    }
  </style>
</Base>
