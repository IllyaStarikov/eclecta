---
import Base from '../layouts/Base.astro';
import { site, href } from '../site';
---
<Base title={`404 | ${site.name}`} description="Page not found." compactHeader>
  <section class="nf">
    <p class="nf__code" aria-hidden="true">404</p>
    <h1 class="nf__line">This page fell below the relevance threshold.</h1>
    <nav class="nf__links" aria-label="Elsewhere">
      <a href={href('/')}>Front</a>
      <a href={href('/archive/')}>Archive</a>
      <a href={href('/feeds/')}>Feeds</a>
    </nav>
  </section>

  <style>
    .nf {
      text-align: center;
      padding: clamp(3rem, 12vh, 7rem) 0 3rem;
    }
    .nf__code {
      font-family: var(--sans);
      font-weight: 800;
      font-size: clamp(6rem, 24vw, 14rem);
      line-height: 0.85;
      letter-spacing: -0.05em;
      margin: 0;
      color: var(--accent);
    }
    .nf__line {
      font-family: var(--serif);
      font-weight: 400;
      font-style: italic;
      font-size: 1.2rem;
      color: var(--ink-soft);
      margin: 1.4rem 0 2.2rem;
    }
    .nf__links {
      display: inline-flex;
      gap: 1.8rem;
      border-top: 1px solid var(--hairline-bold);
      padding-top: 1.1rem;
    }
    .nf__links a {
      font-family: var(--mono);
      font-size: 0.74rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }
    .nf__links a:hover { color: var(--accent); }
  </style>
</Base>
