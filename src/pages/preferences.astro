---
import Base from '../layouts/Base.astro';
import { site } from '../site';

interface SegOption {
  value: string;
  label: string;
}
// Radio groups consumed by src/scripts/prefs.js: a div[data-pref-group]
// carries the key's default; the default value is stored as null (removed).
const themeOpts: SegOption[] = [
  { value: 'auto', label: 'Auto' },
  { value: 'light', label: 'Light' },
  { value: 'dark', label: 'Dark' },
];
const fontOpts: SegOption[] = [
  { value: 's', label: 'S' },
  { value: 'm', label: 'M' },
  { value: 'l', label: 'L' },
  { value: 'xl', label: 'XL' },
];
const densityOpts: SegOption[] = [
  { value: 'comfortable', label: 'Comfortable' },
  { value: 'compact', label: 'Compact' },
];
---
<Base title={`Preferences — ${site.name}`} description="Reading preferences: theme, type size, density, signals. Stored on this device only.">
  <section class="prefs">
    <div class="section-head" style="padding-top:2.4rem;">
      <h2>Preferences</h2>
      <span class="count">stored on this device</span>
    </div>
    <p class="hint" style="margin:0 0 1.6rem;">
      Everything here lives in this browser's local storage. Nothing is sent
      anywhere; there is no account.
    </p>

    <noscript>
      <p class="hint" style="border:1px solid var(--rule-bold); padding:0.8rem 1rem; margin:0 0 1.6rem;">
        Preferences need JavaScript. Without it the site reads fine — you just
        get the defaults: auto theme, medium type, comfortable density.
      </p>
    </noscript>

    <fieldset>
      <legend>Display</legend>
      <div class="row">
        <span class="lab" id="lab-theme">Theme</span>
        <div class="seg" data-pref-group data-pref-group-default="auto" role="radiogroup" aria-labelledby="lab-theme">
          {themeOpts.map((o) => (
            <>
              <input type="radio" name="theme" data-pref="theme" value={o.value} id={`theme-${o.value}`} />
              <label for={`theme-${o.value}`}>{o.label}</label>
            </>
          ))}
        </div>
      </div>
      <div class="row">
        <span class="lab" id="lab-fontsize">Type size</span>
        <div class="seg" data-pref-group data-pref-group-default="m" role="radiogroup" aria-labelledby="lab-fontsize">
          {fontOpts.map((o) => (
            <>
              <input type="radio" name="fontSize" data-pref="fontSize" value={o.value} id={`fontsize-${o.value}`} />
              <label for={`fontsize-${o.value}`}>{o.label}</label>
            </>
          ))}
        </div>
      </div>
      <div class="row">
        <span class="lab" id="lab-density">Density</span>
        <div class="seg" data-pref-group data-pref-group-default="comfortable" role="radiogroup" aria-labelledby="lab-density">
          {densityOpts.map((o) => (
            <>
              <input type="radio" name="density" data-pref="density" value={o.value} id={`density-${o.value}`} />
              <label for={`density-${o.value}`}>{o.label}</label>
            </>
          ))}
        </div>
      </div>
      <p class="hint">Compact tightens spacing and folds away the per-pick notes.</p>
    </fieldset>

    <fieldset>
      <legend>Reading</legend>
      <div class="row">
        <input type="checkbox" data-pref="showSignals" id="pref-signals" />
        <label for="pref-signals">Show curation signals</label>
      </div>
      <p class="hint">
        Per pick: where it surfaced (and how loudly), relevance and score, and
        which model curated it.
      </p>
      <div class="row">
        <input type="checkbox" data-pref="showScores" id="pref-scores" />
        <label for="pref-scores">Show scores inline</label>
      </div>
      <p class="hint">Relevance and score chips in each pick's byline.</p>
    </fieldset>

    <fieldset>
      <legend>Thumbs</legend>
      <p class="hint" style="margin-top:0.2rem;">
        The + and − on every pick tune what you see. Votes are device-local:
        they never leave the browser, and nothing about them is collected.
      </p>
      <div class="row">
        <input type="checkbox" data-pref="hideDownvoted" id="pref-hidedown" />
        <label for="pref-hidedown">Hide downvoted picks entirely</label>
      </div>
      <p class="hint">Off, downvoted picks stay visible but dimmed.</p>
      <div class="row" style="margin-top:1rem;">
        <button type="button" class="danger" data-prefs-reset>Clear all preferences &amp; votes</button>
      </div>
    </fieldset>
  </section>

  <style>
    .prefs input[type='checkbox'] {
      appearance: none;
      width: 1rem;
      height: 1rem;
      border: 1px solid var(--rule-bold);
      background: var(--paper);
      cursor: pointer;
      display: inline-grid;
      place-content: center;
      margin: 0;
    }
    .prefs input[type='checkbox']:checked {
      background: var(--ink);
      border-color: var(--ink);
    }
    .prefs input[type='checkbox']:checked::before {
      content: '';
      width: 0.4rem;
      height: 0.4rem;
      background: var(--paper);
    }
    .prefs input[type='checkbox'] + label {
      cursor: pointer;
      font-size: 1rem;
    }
  </style>
</Base>
