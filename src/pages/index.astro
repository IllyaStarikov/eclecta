---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Pick, { type PickData } from '../components/Pick.astro';
import picksJson from '../data/picks.json';
import channels from '../data/channels.json';
import stats from '../data/stats.json';
import { site, href, KIND_LABEL } from '../site';

const digests = (await getCollection('digests')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
// Lead with the most substantial recent edition (weekly+), and surface the
// latest daily brief as a strip beneath it. If only dailies exist, lead daily.
const longform = digests.find((d) => d.data.kind !== 'daily');
const latestDaily = digests.find((d) => d.data.kind === 'daily');
const lead = longform ?? digests[0];
const daily = latestDaily && latestDaily.id !== lead?.id ? latestDaily : null;

// JSON import inference produces a per-entry union; the zod contract in
// lib/schema (unit-tested in CI) is the real validator.
const picks = picksJson as unknown as PickData[];

// The Brief (the digest hero) is the page's editorial lead when an edition
// exists. THE PICKS always carries its OWN ranked #1 (rendered large) so the
// section never collapses into a flat wall: pick 1 is the lede, 2–8 are
// briefing rows, and the long tail downshifts to Also Notable.
const leadRow = picks[0] ?? null;
const briefRows = picks.slice(1, 8);
const also = picks.slice(8, 22);
const shown = (leadRow ? 1 : 0) + briefRows.length + also.length;
const overflow = picks.length - shown;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const sourceCount = stats?.sources?.verified ?? stats?.sources?.total ?? null;
const picksLabel = `${picks.length} curated${sourceCount ? ` · ${sourceCount.toLocaleString('en-US')} sources read` : ''}`;
---
<Base>
  <p class="standfirst reveal">
    {site.name} watches where technology, AI, and the sciences break first, and
    keeps almost none of it. Stories that surface across many independent sources
    are read closely, scored, and explained. Every pick links the primary
    source, with a free read when the original is walled.
    <a href={href('/about/')}>How it works →</a>
    {sourceCount && (
      <span class="figures">
        {sourceCount.toLocaleString('en-US')} sources · daily brief on weekday
        mornings · digests weekly to yearly
      </span>
    )}
  </p>

  {lead && (
    <section class="reveal" aria-label="Latest edition">
      <div class="rail">
        <span class="rail__label">The Brief</span>
        <span class="rail__rule"></span>
        <span class="rail__count">{KIND_LABEL[lead.data.kind]}</span>
      </div>
      <div class="lead-block">
        <div class="lead">
          <div class="lead__meta">
            <span class="label">{KIND_LABEL[lead.data.kind]}</span>
            <span class="lead__dot" aria-hidden="true">▪</span>
            <span class="label"><span class="lead__serial">{lead.data.period}</span> · {fmt(lead.data.date)}</span>
          </div>
          <h2 class="lead__title"><a href={href(`/digests/${lead.id}/`)}>{lead.data.title}</a></h2>
          <p class="lead__blurb">{lead.data.blurb}</p>
          <a class="cta" href={href(`/digests/${lead.id}/`)}>
            Read the {lead.data.kind === 'daily' ? 'brief' : 'digest'} <span aria-hidden="true">→</span>
          </a>
        </div>
        {daily && (
          <div class="today">
            <span class="label today__kind">Today</span>
            <h3 class="today__title">
              <a href={href(`/digests/${daily.id}/`)}>{daily.data.title}</a>
            </h3>
            <span class="today__blurb">{daily.data.blurb}</span>
          </div>
        )}
      </div>
    </section>
  )}

  <div class="rail">
    <span class="rail__label">The Picks</span>
    <span class="rail__rule"></span>
    <span class="rail__count">{picksLabel}</span>
  </div>

  <div class="briefing">
    {leadRow && <Pick pick={leadRow} index={0} variant="lead" />}
    {briefRows.map((p, i) => <Pick pick={p} index={i + 1} variant="brief" />)}
  </div>

  {also.length > 0 && (
    <Fragment>
      <div class="rail">
        <span class="rail__label">Also Notable</span>
        <span class="rail__rule"></span>
      </div>
      <div class="also">
        {also.map((p, i) => <Pick pick={p} index={i} variant="also" />)}
      </div>
    </Fragment>
  )}

  {overflow > 0 && (
    <p class="more-note">
      + {overflow} more across the <a href={href('/feeds/')}>channels and feeds</a>
    </p>
  )}

  <section class="subscribe reveal">
    <span class="label" style="color:var(--accent-ink);">Subscribe</span>
    <h2>Read it in your feed reader.</h2>
    <p>
      No inbox, no algorithm. Point any RSS reader at a feed and the best of it
      arrives as it’s curated — or take only the digests, or only a channel.
    </p>
    <div class="feeds">
      <a class="feed-chip" href={href('/rss.xml')}><span class="dot"></span>Everything</a>
      <a class="feed-chip" href={href('/digests/rss.xml')}><span class="dot"></span>Digests</a>
      {channels.map((c) => (
        <a class="feed-chip" href={href(`/${c.slug}/rss.xml`)}><span class="dot"></span>{c.name}</a>
      ))}
    </div>
    <p style="margin-top:1.2rem;">
      <a class="cta" href={href('/feeds/')}>All feeds <span aria-hidden="true">→</span></a>
    </p>
  </section>
</Base>
