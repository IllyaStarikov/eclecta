---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { site, href, KINDS, KIND_LABEL } from '../site';

const digests = (await getCollection('digests')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
// Group by kind in KINDS order; skip kinds with nothing published yet.
const groups = KINDS.map((kind) => ({
  kind,
  entries: digests.filter((d) => d.data.kind === kind),
})).filter((g) => g.entries.length > 0);
---
<Base title={`Archive — ${site.name}`} description="Every edition Eclecta has published, daily brief to the year in review.">
  <div class="section-head section-head--page">
    <h1>The archive</h1>
  </div>

  {groups.map((g) => (
    <section>
      <div class="rail">
        <h2 class="rail__label">{KIND_LABEL[g.kind]}</h2>
        <span class="rail__rule"></span>
        <a class="chip" href={href(`/digests/${g.kind}/rss.xml`)}>
          <span class="chip__dot"></span>{KIND_LABEL[g.kind]} feed
        </a>
      </div>
      <div class="briefing">
        {g.entries.map((d, i) => (
          <article class="pick reveal arch" style={`animation-delay:${Math.min(i, 8) * 50}ms`}>
            <div class="label arch__period">{d.data.period}</div>
            <div>
              <h3 class="pick__title">
                <a href={href(`/digests/${d.id}/`)}>{d.data.title}</a>
              </h3>
              <p class="pick__why">{d.data.blurb}</p>
            </div>
          </article>
        ))}
      </div>
    </section>
  ))}
</Base>
