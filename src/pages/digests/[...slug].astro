---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { site, href, KIND_LABEL } from '../../site';

export async function getStaticPaths() {
  const digests = await getCollection('digests');
  return digests.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });

// prev/next within the same kind, newest first
const siblings = (await getCollection('digests'))
  .filter((d) => d.data.kind === entry.data.kind)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const i = siblings.findIndex((d) => d.id === entry.id);
const newer = i > 0 ? siblings[i - 1] : null;
const older = i >= 0 && i < siblings.length - 1 ? siblings[i + 1] : null;
---
<Base feedLinks={[{ title: `${site.name} | ${KIND_LABEL[entry.data.kind]}`, href: href(`/digests/${entry.data.kind}/rss.xml`) }]} title={`${entry.data.title} | ${site.name}`} description={entry.data.blurb} compactHeader edition={`${KIND_LABEL[entry.data.kind]} ${entry.data.period}`}>
  <a class="arrow-link back" href={href('/archive/')}><span aria-hidden="true">←</span> Archive</a>
  <article class="article measure measure--center">
    <header class="article__head">
      <div class="article__meta">
        <span class="label article__kind">{KIND_LABEL[entry.data.kind]}</span>
        <span class="label article__serial">{entry.data.period}</span>
        <span class="label">{fmt(entry.data.date)}</span>
      </div>
      <h1 class="article__title">{entry.data.title}</h1>
      {entry.data.blurb && <p class="article__standfirst">{entry.data.blurb}</p>}
    </header>
    <div class="prose">
      <Content />
    </div>
    <footer class="article__foot">
      {entry.data.model && <span class="label label--faint">Written by {entry.data.model}</span>}
      <a class="arrow-link" href={href(`/digests/${entry.data.kind}/rss.xml`)}>{KIND_LABEL[entry.data.kind]} feed <span aria-hidden="true">→</span></a>
      <a class="arrow-link arrow-link--faint" href={href('/feeds/')}>All feeds <span aria-hidden="true">→</span></a>
    </footer>
  </article>
  <nav class="digest-nav measure measure--center" aria-label="More digests">
    <span>
      {older && <a class="arrow-link back" href={href(`/digests/${older.id}/`)}><span aria-hidden="true">←</span> {older.data.title}</a>}
    </span>
    <span>
      {newer && <a class="arrow-link back" href={href(`/digests/${newer.id}/`)}>{newer.data.title} <span aria-hidden="true">→</span></a>}
    </span>
  </nav>
</Base>
