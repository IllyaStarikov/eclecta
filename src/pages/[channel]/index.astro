---
import Base from '../../layouts/Base.astro';
import Pick, { type PickData } from '../../components/Pick.astro';
import picksJson from '../../data/picks.json';
import channels from '../../data/channels.json';
import { site, href } from '../../site';

export function getStaticPaths() {
  return channels.map((c) => ({ params: { channel: c.slug }, props: { channel: c } }));
}
const { channel } = Astro.props;
// JSON import inference yields a union; lib/schema's zod contract validates.
const picks = picksJson as unknown as PickData[];
const list = picks.filter((p) => p.channels.includes(channel.slug));
// Give the channel a top, a body, and a tail instead of one flat ribbon:
// promote the strongest pick to the lede, the rest are briefing rows.
const [channelLead, ...channelRest] = list;
---
<Base title={`${channel.name} — ${site.name}`} description={channel.blurb}>
  <div class="section-head" style="padding-top:2.4rem;">
    <h2>{channel.name}</h2>
    <span class="count">{list.length} {list.length === 1 ? 'pick' : 'picks'}</span>
  </div>
  <p class="measure" style="color:var(--ink-soft); font-style:italic; margin:0 0 0.6rem;">{channel.blurb}</p>
  <p>
    <a class="feed-chip" href={href(`/${channel.slug}/rss.xml`)}><span class="dot"></span>Subscribe to {channel.name}</a>
  </p>
  {list.length > 0 ? (
    <div class="briefing" style="margin-top:1.4rem; border-top:1px solid var(--hairline-bold);">
      {channelLead && <Pick pick={channelLead} index={0} variant="lead" />}
      {channelRest.length > 0 && (
        <div class="rail">
          <span class="rail__label">More in {channel.name}</span>
          <span class="rail__rule"></span>
          <span class="rail__count">{channelRest.length}</span>
        </div>
      )}
      {channelRest.map((p, i) => <Pick pick={p} index={i + 1} variant="brief" />)}
    </div>
  ) : (
    <p style="padding:2rem 0; color:var(--ink-soft); font-style:italic;">Nothing curated in this channel yet this week.</p>
  )}
</Base>
