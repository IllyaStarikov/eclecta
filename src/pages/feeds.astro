---
import Base from '../layouts/Base.astro';
import { site, absUrl, href } from '../site';
import { FEEDS, type FeedGroup } from '../lib/feeds';

const GROUPS: { key: FeedGroup; title: string; note: string }[] = [
  { key: 'everything', title: 'Everything', note: 'The whole publication in one feed.' },
  { key: 'digests', title: 'Digests', note: 'Editions only, no individual picks.' },
  { key: 'cadence', title: 'By cadence', note: 'One edition kind at a time.' },
  { key: 'category', title: 'By section', note: 'Picks from a single section.' },
];
const feedsFor = (g: FeedGroup) => FEEDS.filter((f) => f.group === g);
---
<Base title={`Feeds | ${site.name}`} description="Every RSS feed Eclecta publishes: everything, digests only, per cadence, per channel.">
  <section class="feeds-page">
    <div class="section-head" style="padding-top:2.4rem;">
      <h1>Feeds</h1>
    </div>
    <p class="measure" style="color:var(--ink-soft); font-style:italic; margin:0 0 var(--space-5);">
      {site.name} lives in your feed reader. Take all of it, or exactly the
      slice you want. Every feed below is plain RSS.
    </p>

    {GROUPS.map((g) => (
      <section class="feed-group">
        <h2 class="feed-group__title">{g.title}</h2>
        <p class="feed-group__note">{g.note}</p>
        <ul class="feed-list">
          {feedsFor(g.key).map((f) => (
            <li>
              <a class="feed-list__title" href={href(f.path)}>{f.title}</a>
              <p class="feed-list__desc">{f.description}</p>
              <code>{absUrl(f.path, Astro.site)}</code>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>

  <style>
    .feed-group { margin-top: var(--space-7); }
    .feed-group__title {
      font-family: var(--sans); font-weight: 700; font-size: 1.3rem;
      letter-spacing: -0.015em; margin: 0; padding-bottom: 0.4rem;
      border-bottom: 1px solid var(--hairline-bold);
    }
    .feed-group__note {
      margin: 0.5rem 0 0; color: var(--ink-soft); font-size: 0.98rem; max-width: 48ch;
    }
    .feed-list {
      list-style: none; margin: var(--space-5) 0 0; padding: 0;
      display: grid; grid-template-columns: repeat(auto-fill, minmax(21rem, 1fr));
      gap: var(--space-5) var(--space-6);
    }
    .feed-list__title {
      font-family: var(--sans); font-weight: 600; font-size: 1.12rem; letter-spacing: -0.01em;
    }
    .feed-list__title:hover { color: var(--accent); }
    .feed-list__desc { margin: 0.25rem 0 0.5rem; color: var(--ink-soft); font-size: 0.95rem; }
    .feed-list code {
      font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.02em;
      color: var(--ink-faint); border: 1px solid var(--hairline);
      padding: 0.25rem 0.5rem; display: inline-block; user-select: all; overflow-wrap: anywhere;
    }
  </style>
</Base>
