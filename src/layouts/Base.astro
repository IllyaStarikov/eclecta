---
import '@fontsource-variable/schibsted-grotesk/wght.css';
import schibstedWoff2 from '@fontsource-variable/schibsted-grotesk/files/schibsted-grotesk-latin-wght-normal.woff2?url';
import serifWoff2 from '@fontsource-variable/source-serif-4/files/source-serif-4-latin-opsz-normal.woff2?url';
import '@fontsource-variable/source-serif-4/opsz.css';
import '@fontsource-variable/source-serif-4/opsz-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import { getCollection } from 'astro:content';
import rawStats from '../data/stats.json';
import { site, href, KIND_LABEL } from '../site';
import { CATEGORIES } from '../lib/taxonomy';

interface Props {
  title?: string;
  description?: string;
  /** widen the shell to the broadsheet width (front + category pages) */
  wide?: boolean;
  /** extra RSS autodiscovery links for this page's own feed(s) */
  feedLinks?: { title: string; href: string }[];
  /** open-graph object type: article for dated editions, website otherwise */
  ogType?: 'website' | 'article';
  /** ISO publish date, emitted as article:published_time when ogType=article */
  publishedTime?: string;
  /** absolute URL of the share card; defaults to the site-wide card */
  ogImage?: string;
  /** page-level JSON-LD object (Base adds WebSite on the front page) */
  jsonLd?: Record<string, unknown>;
}
const {
  title = `${site.name} | the best of technology, AI & science`,
  description = site.description,
  wide = false,
  feedLinks = [],
  ogType = 'website',
  publishedTime,
  ogImage,
  jsonLd,
} = Astro.props;
const year = new Date().getFullYear();

// The issue number is real: every published edition counts, so the dateline's
// "No." increments exactly when the archive grows. Newest first, so the dateline
// can link its issue number straight to the current edition.
const digests = (await getCollection('digests')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const editionNo = digests.length;
const latestEdition = digests[0] ?? null;

// Dateline / colophon — the wire's "as of". Prefer the pipeline's last run.
const generatedAt = (rawStats as { generated_at?: string }).generated_at;
const asOf = generatedAt ? new Date(generatedAt) : new Date();
const wireDate = asOf.toLocaleDateString('en-US', {
  weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC',
});
const asOfStamp = asOf.toISOString().slice(0, 16).replace('T', ' ');
// Astro.url.pathname already includes the base path.
const origin = Astro.site ? String(Astro.site).replace(/\/+$/, '') : '';
const canonical = origin + Astro.url.pathname;
const shareImage = ogImage ?? origin + href('/og/default.png');
const isFront = Astro.url.pathname === href('/') || Astro.url.pathname === href('/') + '/';
const websiteLd = isFront
  ? { '@context': 'https://schema.org', '@type': 'WebSite', name: site.name, url: origin + href('/'), description: site.description }
  : null;
const ldBase = jsonLd ?? websiteLd;
// EU AI Act Art. 50(2): AI-generated editorial text is marked in a
// machine-readable form. Augment any emitted structured data with a software
// creator + the IPTC DigitalSourceType term for model-generated media. The
// human-readable disclosure lives on /about, /contact and /coverage.
const ld = ldBase
  ? {
      ...ldBase,
      creator: {
        '@type': 'SoftwareApplication',
        name: 'signalpipe',
        applicationCategory: 'Automated news curation',
        url: site.repoUrl,
      },
      creditText: 'Editorial text generated by automated language models.',
      digitalSourceType: 'https://cv.iptc.org/newscodes/digitalsourcetype/trainedAlgorithmicMedia',
    }
  : ldBase;
const currentPath = Astro.url.pathname;
const isCurrent = (path: string) => (currentPath === href(path) || currentPath === href(path) + '/') ? 'page' : undefined;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} | everything`} href={href('/rss.xml')} />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} | digests`} href={href('/digests/rss.xml')} />
    {feedLinks.map((f) => (
      <link rel="alternate" type="application/rss+xml" title={f.title} href={f.href} />
    ))}
    <link rel="preload" as="font" type="font/woff2" crossorigin href={schibstedWoff2} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={serifWoff2} />
    <link rel="icon" href={href('/favicon.svg')} type="image/svg+xml" />
    <meta name="color-scheme" content="light dark" />
    <meta name="author" content={site.author} />
    <meta name="ai-generated" content="true" />
    <meta name="ai-content-declaration" content="Editorial text on this site is generated by automated language models (signalpipe); see the About page." />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    <meta property="og:image" content={shareImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImage} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f1f2f0" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#101214" />
    {ld && <script type="application/ld+json" set:html={JSON.stringify(ld)} />}
    <meta name="generator" content={Astro.generator} />
    <script is:inline define:vars={{ prefix: site.storagePrefix + ':' }}>
      // Pre-paint preference stamp — keep in sync with src/scripts/prefs.js.
      (function () {
        try {
          var g = function (k) { return localStorage.getItem(prefix + k); };
          var d = document.documentElement;
          var stamp = function (key, attr, ok) {
            var v = g(key);
            if (v && ok.indexOf(v) !== -1) d.setAttribute('data-' + attr, v);
          };
          stamp('theme', 'theme', ['light', 'dark']);
          stamp('accent', 'accent', ['cobalt', 'moss', 'plum', 'ink']);
          stamp('fontSize', 'fontsize', ['s', 'l', 'xl']);
          stamp('bodyFont', 'bodyfont', ['sans']);
          stamp('density', 'density', ['compact']);
          stamp('leading', 'leading', ['tight', 'relaxed']);
          stamp('measure', 'measure', ['narrow', 'wide']);
          stamp('motion', 'motion', ['reduce']);
          var flags = [
            ['showScores', 'showscores'], ['showSignals', 'showsignals'],
            ['justify', 'justify'], ['underlineLinks', 'underline'],
            ['wideSpacing', 'widespacing'],
          ];
          for (var i = 0; i < flags.length; i++) {
            if (g(flags[i][0]) === '1') d.setAttribute('data-' + flags[i][1], '1');
          }
          var c = g('contrast');
          if (c === 'high' || (!c && matchMedia('(prefers-contrast: more)').matches)) {
            d.setAttribute('data-contrast', 'high');
          }
          var muted = g('mutedCategories');
          if (muted) d.setAttribute('data-muted', muted.split(',').filter(Boolean).join(' '));
        } catch (e) { /* first paint falls back to defaults */ }
      })();
    </script>
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header>
      <div class="wrap">
        <div class="masthead">
          <p class="masthead__wordmark"><a href={href('/')} aria-label={`${site.name} | front page`}>{site.name}<span class="period" aria-hidden="true"></span></a></p>
          <div class="masthead__kicker">
            <span class="label">{site.kicker}</span>
            <span class="masthead__tag">{site.tagline}</span>
          </div>
        </div>
      </div>
      <div class="wrap">
        <div class="dateline">
          <span class="dateline__date">{wireDate}</span>
          <span class="dateline__edition">No. {editionNo}{latestEdition && (<> · <a href={href(`/digests/${latestEdition.id}/`)}>{KIND_LABEL[latestEdition.data.kind]}</a></>)}</span>
        </div>
      </div>
      <div class="wrap">
        <nav class="channels" aria-label="Sections">
          <a href={href('/')} aria-current={isCurrent('/')}>Front</a>
          {CATEGORIES.map((c) => (
            <a href={href(`/${c.slug}/`)} data-category={c.slug} aria-current={isCurrent(`/${c.slug}/`)}>{c.name}</a>
          ))}
          <a href={href('/archive/')} aria-current={isCurrent('/archive/')}>Archive</a>
          <a href={href('/feeds/')} aria-current={isCurrent('/feeds/')}>Feeds</a>
          <a href={href('/about/')} aria-current={isCurrent('/about/')}>About</a>
          <a href={href('/preferences/')} aria-current={isCurrent('/preferences/')}>Prefs</a>
          <a href={site.repoUrl}>Source</a>
          <button class="toggle" type="button" data-theme-toggle aria-label="Theme: auto. Click to change">auto</button>
        </nav>
      </div>
    </header>

    <main class="wrap" id="main">
      {wide ? <slot /> : <div class="column"><slot /></div>}
    </main>

    <footer class="wrap foot">
      <div class="foot__id">
        <span class="foot__name">{site.name}<span class="period" aria-hidden="true"></span></span>
        <p>
          Machines read the feeds, thousands of sources at a time, and distill
          what matters into a daily brief and the longer views. Every line of
          the pipeline and this site is open source.
        </p>
        <span class="foot__colophon"><span>Updated {asOfStamp} UTC</span><span>No. {editionNo}</span></span>
      </div>
      <nav class="foot__col" aria-label="Read">
        <span class="label foot__head">Read</span>
        <a href={href('/')}>Front page</a>
        <a href={href('/archive/')}>Archive</a>
        <a href={href('/feeds/')}>Feeds</a>
        <a href={href('/preferences/')}>Preferences</a>
      </nav>
      <nav class="foot__col" aria-label="The wire">
        <span class="label foot__head">The wire</span>
        <a href={href('/about/')}>How it works</a>
        <a href={href('/coverage/')}>Coverage</a>
        <a href={href('/sources/')}>Sources</a>
        <a href={href('/contact/')}>Contact</a>
      </nav>
      <nav class="foot__col" aria-label="Made by">
        <span class="label foot__head">Made by</span>
        <a href={site.repoUrl}>Open source, MIT</a>
        <a href={href('/about/#how-it-works')}>Colophon</a>
        <a href={site.authorUrl}>starikov.co</a>
        <span class="foot__copy">© {year}</span>
      </nav>
    </footer>
    <script>
      import '../scripts/prefs.js';
    </script>
  </body>
</html>
