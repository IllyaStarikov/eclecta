---
/**
 * The edition rail — the right-hand column of the broadsheet layout.
 * Carries the edition furniture (section index, editions, subscribe) so the
 * main column stays a clean reading sequence. Every block is optional; pass
 * only what a page needs. Index/nav items take a `category` so muted
 * categories hide from the rail exactly as they do from the sections.
 *
 * The section index is live: a ▪ marker tracks the section under the reader's
 * eye and glides down the list as they scroll (the mark as reading indicator —
 * see design-language.md §The mark). Progressive enhancement: without JS the
 * index is a plain anchor list and no marker renders.
 */
export interface RailLink {
  label: string;
  href: string;
  meta?: string | number | null;
  category?: string | null;
  current?: boolean;
}
export interface RailBlock {
  title: string;
  items: RailLink[];
  moreLabel?: string;
  moreHref?: string;
}
interface Props {
  index?: RailBlock | null;
  nav?: RailBlock | null;
  editions?: RailBlock | null;
  feeds?: RailBlock | null;
  back?: RailLink | null;
}
const {
  index = null,
  nav = null,
  editions = null,
  feeds = null,
  back = null,
} = Astro.props;
const hasMeta = (m: RailLink['meta']) => m != null && m !== '';
---
<aside class="erail" aria-label="Edition guide">
  {index && index.items.length > 0 && (
    <nav class="erail__block erail__index" data-scrollspy aria-label={index.title}>
      <span class="erail__head">{index.title}</span>
      <ul class="erail__list">
        {index.items.map((it) => (
          <li data-category={it.category ?? undefined}>
            <a href={it.href} aria-current={it.current ? 'page' : undefined}>
              <span class="erail__name">{it.label}</span>
              {hasMeta(it.meta) && <span class="erail__n">{it.meta}</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  {nav && nav.items.length > 0 && (
    <nav class="erail__block erail__nav" aria-label={nav.title}>
      <span class="erail__head">{nav.title}</span>
      <ul class="erail__list">
        {nav.items.map((it) => (
          <li data-category={it.category ?? undefined}>
            <a href={it.href} aria-current={it.current ? 'page' : undefined}>
              <span class="erail__name">{it.label}</span>
              {hasMeta(it.meta) && <span class="erail__n">{it.meta}</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  {editions && editions.items.length > 0 && (
    <div class="erail__block erail__editions">
      <span class="erail__head">{editions.title}</span>
      <ul class="erail__list">
        {editions.items.map((it) => (
          <li>
            <a href={it.href}>
              <span class="erail__name">{it.label}</span>
              {hasMeta(it.meta) && <span class="erail__n">{it.meta}</span>}
            </a>
          </li>
        ))}
      </ul>
      {editions.moreHref && (
        <a class="arrow-link arrow-link--faint erail__more" href={editions.moreHref}>{editions.moreLabel ?? 'More'} <span aria-hidden="true">→</span></a>
      )}
    </div>
  )}

  {feeds && feeds.items.length > 0 && (
    <div class="erail__block erail__sub">
      <span class="erail__head">{feeds.title}</span>
      <ul class="erail__feeds">
        {feeds.items.map((it) => (
          <li>
            <a href={it.href}>{it.label}</a>
          </li>
        ))}
      </ul>
      {feeds.moreHref && (
        <a class="arrow-link arrow-link--faint erail__more" href={feeds.moreHref}>{feeds.moreLabel ?? 'All feeds'} <span aria-hidden="true">→</span></a>
      )}
    </div>
  )}

  {back && (
    <a class="arrow-link" href={back.href}><span aria-hidden="true">←</span> {back.label}</a>
  )}
</aside>

<script>
  // The reading marker: a ▪ that tracks the visible section in the index.
  // One IntersectionObserver per page; "active" = the last section whose top
  // has passed the reading band (upper 40% of the viewport), so the marker
  // steps down exactly when the reader's section changes.
  const spy = document.querySelector('[data-scrollspy]');
  const list = spy?.querySelector('.erail__list');
  if (spy instanceof HTMLElement && list instanceof HTMLElement) {
    const links = [...spy.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')];
    const targets = links
      .map((a) => {
        const el = document.getElementById(decodeURIComponent(a.hash.slice(1)));
        return el ? { a, el } : null;
      })
      .filter((t): t is { a: HTMLAnchorElement; el: HTMLElement } => t !== null);

    if (targets.length > 0) {
      const marker = document.createElement('span');
      marker.className = 'erail__marker';
      marker.setAttribute('aria-hidden', 'true');
      list.append(marker);

      let current: HTMLAnchorElement | null = null;
      const place = () => {
        // Muted categories collapse their <li>; skip hidden entries.
        if (current && current.offsetParent === null) current = null;
        if (!current) {
          const first = targets.find((t) => t.a.offsetParent !== null);
          current = first ? first.a : null;
        }
        if (!current) {
          marker.style.opacity = '0';
          return;
        }
        const li = current.closest('li');
        if (!(li instanceof HTMLElement)) return;
        marker.style.opacity = '1';
        marker.style.transform = `translateY(${li.offsetTop + li.offsetHeight / 2}px)`;
        for (const t of targets) {
          if (t.a === current) t.a.setAttribute('aria-current', 'location');
          else t.a.removeAttribute('aria-current');
        }
      };

      const setCurrent = () => {
        // Last section whose top sits above the reading band = the one in view.
        const band = window.innerHeight * 0.4;
        let active: HTMLAnchorElement | null = null;
        for (const t of targets) {
          if (t.a.offsetParent === null) continue;
          if (t.el.getBoundingClientRect().top <= band) active = t.a;
        }
        current = active ?? null;
        place();
      };

      // Observe section edges to wake up only when the answer can change;
      // recompute the winner from geometry (order-safe and mute-safe).
      const io = new IntersectionObserver(setCurrent, {
        rootMargin: '-40% 0px -59% 0px',
      });
      for (const t of targets) io.observe(t.el);
      window.addEventListener('resize', setCurrent, { passive: true });
      // Preference changes (muting a section) re-layout the rail.
      new MutationObserver(setCurrent).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-muted'],
      });
      setCurrent();
    }
  }
</script>
