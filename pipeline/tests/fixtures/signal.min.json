{
  "db_path": "~/.local/state/signal/signal.db",
  "user_agent": "signalpipe-test/0.1 (+https://eclecta.co; test)",
  "server": {
    "host": "127.0.0.1",
    "port": 8765,
    "auto_refresh_sec": 120,
    "feed_default_limit": 50,
    "feed_max_limit": 200,
    "feed_title": "Signal test feed",
    "feed_link": "http://127.0.0.1:8765/",
    "feed_description": "test feed"
  },
  "backend": {
    "selector": "subscription",
    "cli_bin": "claude",
    "cli_timeout_sec": 900,
    "cli_extra_args": [],
    "quota_recheck_min": 30,
    "tier_overrides": {},
    "local": {
      "base_url": "http://127.0.0.1:11434",
      "models": ["qwen2.5:14b"],
      "timeout_sec": 600,
      "num_ctx": 16384,
      "fallback": "subscription"
    }
  },
  "tiers": {
    "triage": { "subscription": "claude-haiku-4-5", "api": "claude-haiku-4-5", "local": "qwen2.5:14b" },
    "deep": { "subscription": "claude-sonnet-4-6", "api": "claude-sonnet-4-6" },
    "judge": { "subscription": "claude-haiku-4-5", "api": "claude-haiku-4-5", "local": "qwen2.5:14b" },
    "write": { "subscription": "claude-sonnet-4-6", "api": "claude-sonnet-4-6", "local": "qwen2.5:14b" },
    "digest": { "subscription": "claude-opus-4-8", "api": "claude-opus-4-8" }
  },
  "cadences": {
    "ingest_min": 45,
    "score_min": 60,
    "fetch_min": 90,
    "curate_min": 15,
    "publish_refresh_min": 90,
    "jitter_sec": 120,
    "misfire_grace_sec": 3600
  },
  "digests": {
    "daily": { "cron": "0 7 * * mon-fri", "min_relevance": 6, "max_items": 25 },
    "weekly": { "cron": "30 7 * * fri", "min_relevance": 7, "max_items": 40 }
  },
  "site": {
    "repo": "/tmp/eclecta-test",
    "branch": "main",
    "remote": "origin",
    "name": "Eclecta",
    "url": "https://eclecta.co",
    "push": false,
    "picks_window_days": 7,
    "picks_limit": 60
  },
  "funnel": {
    "score_window_hours": 72,
    "daily_finalists": 80,
    "triage_band": [3.5, 6.0],
    "min_score_to_curate": 3.5,
    "min_relevance_for_feed": 6,
    "curate_batch": 3
  },
  "spend": {
    "daily_cap_usd": 10.0,
    "digest_cap_usd": 3.0,
    "stop_curate_on_cap": true,
    "failed_call_estimate_usd": 0.02
  },
  "downtime": {
    "enabled": true,
    "idle_min": 5,
    "require_ac": true,
    "thermal_guard": true,
    "min_free_gb_curation": 14,
    "min_free_gb_digest": 12,
    "editions_interval_min": 30
  },
  "channels": ["ai", "ml-research", "devtools", "security", "hardware", "startups", "science", "everything"],
  "score_weights": {
    "consensus": 0.3,
    "engagement": 0.25,
    "reputation": 0.15,
    "recency": 0.15,
    "topic_match": 0.15,
    "recency_halflife_hours": 18
  },
  "paywall": {
    "allow_archive_today": false,
    "paywall_domains": ["nytimes.com", "wsj.com", "ft.com"],
    "free_source_chain": ["primary", "publication-free", "freedium", "canonical-fallback"],
    "min_words_not_paywalled": 150
  },
  "dedup": {
    "title_jaccard_same_domain": 0.8,
    "title_jaccard_cross_domain": 0.92,
    "near_dup_window_hours": 48
  },
  "ingest": {
    "per_host_min_interval_sec": 2.0,
    "http_timeout_sec": 20,
    "max_redirects": 5,
    "hn_pages": 2,
    "lobsters_pages": 2,
    "reddit_mode": "public_json",
    "reddit_subs": ["programming", "MachineLearning"],
    "arxiv_categories": ["cs.AI", "cs.LG"],
    "gnews_topics": ["TECHNOLOGY"],
    "gnews_resolve_top": 25,
    "wiki_events_days": 2,
    "gdelt_queries": ["artificial intelligence sourcelang:eng"],
    "mastodon_instances": ["mastodon.social"],
    "enable_devto": true,
    "enable_stackexchange": true,
    "github_trending": true,
    "hf_daily_papers": true
  },
  "sources": {
    "registry": "signalpipe/sources.json",
    "opml": "signalpipe/sources.opml"
  }
}
